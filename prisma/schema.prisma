generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
  SUSPENDED
  PENDING
  EXPIRING_SOON
}

enum UserRole {
  AGENT
  ADMIN
  OWNER
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum Status {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum TeamAccess {
  ALL
  SALES
  SUPPORT
  PROJECT_MANAGER
}

enum MediaType {
  VOICE_MAIL
  ON_HOLD
  CALLBACK_MESSAGE
  EMAIL_VIDEO
}

enum FileCategory {
  audio
  video
}

enum EventType {
  START_ONLY
  FROM_TO
  ALL_DAY
}

enum PhoneType {
  MOBILE
  TELEPHONE
  HOME
  WORK
}

enum IntegrationProvider {
  TWILIO
  GOOGLE_MAPS
  REALTOR_DOT_COM
  BOMB_BOMB
  GMAIL
  STANPP_DOT_COM
  MY_PLUS_LEADS
  ZAPIER
  ZOHO
}

enum IntegrationStatus {
  CONNECTED
  FAILED
  PROCESSING
  NEED_SETUP
}

enum ActionSchedType {
  FREQUENCY_BASED
  DATE_BASED
}

enum ActionStepType {
  EMAIL
  PHONE_CALL
  TASK
  LETTER
  MAILING_LABEL
}

enum ActionTriggerType {
  NONE
  CALLING_LIST
  GROUP
}

enum ActionEndLogic {
  DO_NOTHING
  REPEAT_PLAN
  START_OTHER_PLAN
}

enum LeadSheetQuestionType {
  TEXTFIELD
  DROPDOWN
  CHECKBOX
  RADIO
  DATETIME
}

enum DialerType {
  PREDICTIVE
  POWER
  PREVIEW
}

enum RecordingType {
  VOICE_MAIL
  ON_HOLD
  EMAIL_VIDEO
}

enum RecordingSlot {
  ON_HOLD
  IVR
  ANSWERING_MACHINE
  VOICEMAIL
  GENERAL
}

enum ExportType {
  LIST
  GROUP
  ALL_CONTACTS
}

model User {
  id       String   @id @default(uuid())
  fullName String?
  email    String   @unique
  password String?
  role     UserRole @default(AGENT)

  status    UserStatus @default(ACTIVE)
  lastLogin DateTime?

  emailVerified Boolean @default(false)
  image         String?

  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  accounts Account[]
  leads    Lead[]

  dataDialers      DataDialer[]
  multiLineDialers MultiLineDialer[]
  libraries        Library[]
  reportAnalytics  Report_Analytic[]
  complianceDNC    Compliance_DNC[]
  auditLogs        AuditLog[]

  systemSettings    System_Setting[]
  billings          Billing[]
  leadStores        LeadStore[]
  userSubscriptions UserSubscription[]
  planFeatures      PlanFeature[]
  products          Product[]

  calendarAssignedTo Calendar[] @relation("CalendarAssignTo")
  calendarAssignedBy Calendar[] @relation("CalendarAssignBy")
  createdById        String?
  createdBy          User?      @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers       User[]     @relation("UserCreator")
  callerIds          CallerId[]
  companies          Company[]

  signature Signature?

  agentSessions AgentSession[]
  callRecords   CallRecord[]

  // All recordings uploaded by this admin — reusable across any settings
  recordings Recording[]

  contactLists   ContactList[]
  contactFolders CotactFolder[]
  contactGroups  ContactGroups[]
  contacts       Contact[]
  importContacts ImportContact[]
  exportContacts ExportContact[]

  @@map("users")
}

model Recording {
  id       String        @id @default(uuid())
  name     String
  url      String
  fileSize Int?
  duration Int?
  mimeType String?
  slot     RecordingSlot @default(GENERAL)

  userId                 String
  user                   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedAsOnHold1          CallSettings[] @relation("OnHoldRecording1")
  usedAsOnHold2          CallSettings[] @relation("OnHoldRecording2")
  usedAsIvr              CallSettings[] @relation("IvrRecording")
  usedAsAnsweringMachine CallSettings[] @relation("AnsweringMachineRecording")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("recordings")
}

model ContactList {
  id         String   @id @default(cuid())
  name       String
  agentIds   String[] @default([])
  contactIds String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  importContacts ImportContact[]
  exportContacts ExportContact[]

  @@map("lists")
}

model CotactFolder {
  id        String   @id @default(cuid())
  name      String
  listIds   String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("folders")
}

model ContactGroups {
  id         String   @id @default(cuid())
  name       String
  contactIds String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  importContacts ImportContact[]
  exportContacts ExportContact[]

  @@map("groups")
}

model Contact {
  id             String   @id @default(cuid())
  fullName       String
  address        String?
  city           String?
  state          String?
  zip            String?
  mailingAddress String?
  mailingCity    String?
  mailingState   String?
  mailingZip     String?
  source         String?
  tags           String[] @default([])
  notes          String?
  dataDialerId   String?
  userId         String?

  dataDialer  DataDialer?    @relation(fields: [dataDialerId], references: [id], onDelete: SetNull)
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  emails      ContactEmail[]
  phones      ContactPhone[]
  attachments Attachment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  callRecords CallRecord[]

  miscValues      Json?
  leadsheetValues Json?
  miscFields      MiscField[]
  miscFieldId     String?

  calendar Calendar[]

  @@index([dataDialerId])
  @@map("contacts")
}

model Attachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String?
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attachments")
}

model ContactEmail {
  id        String  @id @default(cuid())
  email     String
  isPrimary Boolean @default(false)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([email])
}

model ContactPhone {
  id        String    @id @default(cuid())
  number    String
  type      PhoneType
  isDnc     Boolean   @default(false)
  contactId String
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([number])
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verifications")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  price       Int
  category    String
  description String?
  thumbnail   String?
  images      String[]
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

model DataDialer {
  id       String    @id @default(uuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("data_dialers")
}

model MultiLineDialer {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("multi_line_dialers")
}

model Library {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scripts         Script[]
  smsTemplate     SMSTemplate[]
  mediaCenter     MediaCenter[]
  emailTemplate   EmailTemplate[]
  callbackPrompts CallbackPrompt[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("libraries")
}

model Script {
  id         String   @id @default(uuid())
  libraryId  String
  library    Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  scriptName String   @unique
  scriptText String
  status     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SMSTemplate {
  id           String   @id @default(uuid())
  libraryId    String
  library      Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  templateName String   @unique
  content      String
  status       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EmailTemplate {
  id           String   @id @default(uuid())
  libraryId    String
  library      Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  templateName String
  subject      String
  content      String
  status       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([libraryId, templateName])
  @@map("email_templates")
}

model Signature {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CallbackPrompt {
  id            String        @id @default(uuid())
  libraryId     String
  library       Library       @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  templateName  String
  recordingType RecordingType
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([libraryId, templateName])
  @@map("callback_prompts")
}

model MediaCenter {
  id           String       @id @default(uuid())
  libraryId    String
  library      Library      @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  templateName String
  mediaType    MediaType
  fileName     String
  fileUrl      String?
  fileSize     Int
  duration     Int?
  fileCategory FileCategory
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("media_center")
}

model Report_Analytic {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("report_analytics")
}

model Compliance_DNC {
  id        String   @id @default(uuid())
  number    String
  name      String?
  email     String?
  source    String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("compliance_dnc")
}

model System_Setting {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caller_id    CallerId[]
  callSettings CallSettings[]
  miscFields   MiscField[]
  actionPlans  ActionPlan[]
  leadSheets   LeadSheet[]

  dialerSetting       DialerSetting?
  regulatorySetting   RegulatorySetting?
  appearance          Appearance?
  notificationSetting NotificationSetting?
  integrations        Integration[]

  @@map("system_settings")
}

model RegulatorySetting {
  id String @id @default(uuid())

  // TCPA Settings
  tcpaFrom        String  @default("08:00")
  tcpaTo          String  @default("20:00")
  tcpaAutodialing Boolean @default(false)

  // GDPR Settings
  gdprRetentionDays Int     @default(30)
  gdprDeleteRelated Boolean @default(true)

  systemSettingId String         @unique
  systemSetting   System_Setting @relation(fields: [systemSettingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("regulatory_settings")
}

model LeadSheet {
  id    String @id @default(cuid())
  title String @unique

  systemSettingId String
  systemSetting   System_Setting @relation(fields: [systemSettingId], references: [id], onDelete: Cascade)

  questions LeadSheetQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lead_sheets")
}

model LeadSheetQuestion {
  id       String                @id @default(cuid())
  text     String
  type     LeadSheetQuestionType
  options  String[]
  required Boolean?

  leadSheetId String
  leadSheet   LeadSheet @relation(fields: [leadSheetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lead_sheet_questions")
}

model Integration {
  id String @id @default(uuid())

  systemSettingId String
  systemSetting   System_Setting @relation(fields: [systemSettingId], references: [id], onDelete: Cascade)

  provider     IntegrationProvider
  status       IntegrationStatus   @default(NEED_SETUP)
  credentials  Json?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([systemSettingId, provider])
  @@map("integrations")
}

model NotificationSetting {
  id              String         @id @default(uuid())
  systemSettingId String         @unique
  systemSetting   System_Setting @relation(fields: [systemSettingId], references: [id], onDelete: Cascade)

  enableAppointmentReminders Boolean @default(false)
  appointmentReminderEmail   String?

  enableCallActivityReport    Boolean @default(false)
  enableSessionSummaryReport  Boolean @default(false)
  includeAgentsWithNoActivity Boolean @default(false)
  dailyCallReportEmail        String?

  enableAppointmentNotifications Boolean @default(false)
  enableComplianceAlerts         Boolean @default(false)

  updatedAt DateTime @updatedAt

  @@map("notification_settings")
}

model DialerSetting {
  id String @id @default(uuid())

  useTimeShield       Boolean @default(false)
  timeShieldStartTime String?
  timeShieldEndTime   String?

  useAnswerNotificationTone Boolean @default(false)

  deleteDisconnectedNumbers Boolean @default(false)
  deleteFaxNumbers          Boolean @default(false)

  useCallSessionTimer Boolean @default(false)

  systemSettingId String         @unique
  systemSetting   System_Setting @relation(fields: [systemSettingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dialer_settings")
}

model Billing {
  id                  String            @id @default(uuid())
  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceNumber       String            @unique
  plan                Plan
  amount              Int
  date                DateTime
  status              Status
  billingCycle        BillingCycle      @default(MONTHLY)
  usersCount          Int               @default(1)
  nextBillingDate     DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  zohooSubscriptionId String?
  leadStore           LeadStore?
  userSubscription    UserSubscription?

  @@map("billings")
}

model LeadStore {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Int
  isActive    Boolean  @default(true)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingId   String   @unique
  billing     Billing  @relation(fields: [billingId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("lead_stores")
}

model LeadStoreService {
  id          String   @id @default(uuid())
  name        String
  price       Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("lead_store_services")
}

enum LeadCallStatus {
  PENDING
  CALLING
  CALLED
  FAILED
  BUSY
  NO_ANSWER
  HOT
  WARM
  COLD
  CALL_BACK
  DO_NOT_CALL
  NOT_INTERESTED
}

enum AppointmentStatus {
  SET
  MET
  CANCELLED
}

model Lead {
  id        String         @id @default(uuid())
  fullName  String
  email     String
  phone     String
  address   String
  city      String
  state     String
  zip       String
  phoneType String
  priority  Int            @default(0)
  status    LeadCallStatus @default(PENDING)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  callRecords CallRecord[]
  calendars   Calendar[]

  @@map("leads")
}

model UserSubscription {
  id     String             @id @default(uuid())
  userId String
  user   User               @relation(fields: [userId], references: [id])
  plan   Plan
  status SubscriptionStatus @default(ACTIVE)

  startDate       DateTime
  endDate         DateTime?
  zohooCustomerId String?
  amount          String?
  usersCount      Int          @default(1)
  billingCycle    BillingCycle @default(MONTHLY)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  billingId       String?      @unique
  billing         Billing?     @relation(fields: [billingId], references: [id])

  @@map("user_subscriptions")
}

model PlanFeature {
  id          String   @id @default(uuid())
  plan        Plan
  featureName String
  isIncluded  Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  @@map("plan_features")
}

model CallerId {
  id              String         @id @default(cuid())
  label           String
  countryCode     String
  numberOfLines   Int            @default(1)
  systemSettingId String
  twillioNumber   String?
  twillioSid      String?
  systemSetting   System_Setting @relation(fields: [systemSettingId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  agents          User[]
  updatedAt       DateTime       @updatedAt
  dialerType      DialerType?    @default(PREDICTIVE)
  aiPacing        Boolean?       @default(false)

  @@map("caller_id")
}

// ─────────────────────────────────────────────────────────────────────────────
// CALL SETTINGS
// The 4 recording slots now reference Recording rows via FK instead of
// storing raw strings. onDelete: SetNull means if a recording is deleted,
// the slot just becomes null — CallSettings row is never broken.
// ─────────────────────────────────────────────────────────────────────────────

model CallSettings {
  id    String @id @default(cuid())
  label String

  onHoldRecording1Id String?
  onHoldRecording1   Recording? @relation("OnHoldRecording1", fields: [onHoldRecording1Id], references: [id], onDelete: SetNull)

  onHoldRecording2Id String?
  onHoldRecording2   Recording? @relation("OnHoldRecording2", fields: [onHoldRecording2Id], references: [id], onDelete: SetNull)

  ivrRecordingId String?
  ivrRecording   Recording? @relation("IvrRecording", fields: [ivrRecordingId], references: [id], onDelete: SetNull)

  answeringMachineRecordingId String?
  answeringMachineRecording   Recording? @relation("AnsweringMachineRecording", fields: [answeringMachineRecordingId], references: [id], onDelete: SetNull)
  enableAutoPause             Boolean    @default(false)
  enableRecording             Boolean    @default(false)
  sendOutlookAppointment      Boolean    @default(false)
  allowDncCalls               Boolean    @default(false)
  callerId                    String?
  countryCode                 String
  numberOfLines               Int        @default(1)
  ringTime                    Int        @default(30)
  callScriptId                String?
  sendEmail                   Boolean    @default(false)
  sendText                    Boolean    @default(false)

  systemSettingId String
  systemSetting   System_Setting @relation(fields: [systemSettingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("call_settings")
}

model CallAnalysis {
  id           String   @id @default(uuid())
  callSid      String   @unique
  leadId       String
  sentiment    String // POSITIVE | NEUTRAL | NEGATIVE
  confidence   Float
  transcript   String
  aiSummary    String?
  recordingUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("call_analysis")
}

model MiscField {
  id             String   @id @default(uuid())
  type           String
  fieldName      String
  options        String[]
  countFrom      Int?
  countTo        Int?
  allowPastDates Boolean?

  systemSettingId String
  systemSetting   System_Setting @relation(fields: [systemSettingId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  contacts        Contact[]

  @@map("misc_fields")
}

model Appearance {
  id String @id @default(uuid())

  calendar               Boolean @default(true)
  hotlist                Boolean @default(true)
  callingGroupsWorkspace Boolean @default(true)
  dialerHealth           Boolean @default(true)
  callStatistics         Boolean @default(true)
  foldersLists           Boolean @default(true)
  recentActivity         Boolean @default(true)

  bestTimeToCall            Boolean @default(true)
  leadIntelligence          Boolean @default(true)
  aiCoachingCallAnalysis    Boolean @default(true)
  callOutcomeIntelligence   Boolean @default(true)
  efficiencyAutomation      Boolean @default(true)
  complianceRiskMonitoring  Boolean @default(true)
  callingGroupsAiSidekick   Boolean @default(true)
  agentImprovementScores    Boolean @default(true)
  pipelineAccelerationIndex Boolean @default(true)

  lockGroups    Boolean @default(false)
  birthdays     Boolean @default(false)
  homeCloseDate Boolean @default(false)

  timeZone String @default("CST")

  systemSettingId String         @unique
  systemSetting   System_Setting @relation(fields: [systemSettingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appearance")
}

model Calendar {
  id          String    @id @default(cuid())
  title       String
  description String
  color       String
  eventType   EventType
  startDate   DateTime
  endDate     DateTime?

  assignToId String
  assignTo   User   @relation("CalendarAssignTo", fields: [assignToId], references: [id], onDelete: Cascade)
  assignById String
  assignBy   User   @relation("CalendarAssignBy", fields: [assignById], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status AppointmentStatus @default(SET)

  @@map("calendar")
}

model AgentSession {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime DateTime  @default(now())
  endTime   DateTime?
  duration  Int? // In seconds
  type      String    @default("C2C") // e.g., C2C Session
  listId    String? // The contact list dialed during this session

  calls     CallRecord[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("agent_sessions")
}

model CallRecord {
  id        String        @id @default(uuid())
  callSid   String        @unique
  leadId    String?
  lead      Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact?      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?
  session   AgentSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  startTime   DateTime        @default(now())
  endTime     DateTime?
  duration    Int? // In seconds
  status      String // Twilio status: completed, failed, etc.
  disposition LeadCallStatus?

  recordingUrl String?
  transcript   String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("call_records")
}

model ActionPlan {
  id String @id @default(uuid())

  systemSettingId String
  systemSetting   System_Setting @relation(fields: [systemSettingId], references: [id], onDelete: Cascade)

  name              String
  schedulingType    ActionSchedType @default(FREQUENCY_BASED)
  schedulingLogic   ActionSchedType @default(FREQUENCY_BASED)
  weekendScheduling ActionSchedType @default(FREQUENCY_BASED)

  triggerType         ActionTriggerType @default(NONE)
  triggerSourceId     String?
  removeOnTriggerExit Boolean           @default(false)

  endLogic           ActionEndLogic @default(DO_NOTHING)
  endLogicValue      String? // For storing repeat day or other values
  nextPlanId         String?
  assignGroupEnabled Boolean        @default(false)
  assignGroupId      String?

  steps     ActionStep[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("action_plans")
}

model ActionStep {
  id           String         @id @default(uuid())
  order        Int
  actionType   ActionStepType
  contentValue String
  dayOffset    Int            @default(0)

  planId String
  plan   ActionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("action_steps")
}

model Company {
  id              String @id @default(cuid())
  companyName     String
  defaultTimeZone String @default("UTC")
  defaultCurrency String @default("USD")
  dateTimeFormat  String @default("MM/DD/YYYY - hh:mm A")

  zohoSubscriptionsConnected Boolean   @default(false)
  zohoApiKey                 String?
  zohoOrganizationId         String?
  zohoLastSyncedAt           DateTime?

  notifyFailedPayment     Boolean @default(true)
  notifyUpcomingRenewal   Boolean @default(true)
  notifyMaintenanceNotice Boolean @default(true)
  notifyCriticalError     Boolean @default(true)

  emailDailySummary        Boolean @default(true)
  emailWeeklyReport        Boolean @default(true)
  emailNewUserSignups      Boolean @default(false)
  emailSubscriptionChanges Boolean @default(true)
  emailSecurityAlerts      Boolean @default(true)

  minPasswordLength   Int     @default(8)
  passwordExpiryDays  Int?    @default(90)
  requireSpecialChars Boolean @default(true)
  requireNumbers      Boolean @default(true)
  requireUppercase    Boolean @default(true)

  sessionTimeoutMinutes Int @default(30)

  require2faForAdmins Boolean @default(false)
  allow2faForUsers    Boolean @default(true)

  defaultLanguage String @default("en")

  callLogRetentionDays          Int @default(365)
  callRecordingRetentionDays    Int @default(90)
  inactiveUserDataRetentionDays Int @default(180)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("companies")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model ImportContact {
  id             String         @id @default(uuid())
  fileName       String
  type           String
  contactListId  String?
  contactList    ContactList?   @relation(fields: [contactListId], references: [id], onDelete: SetNull)
  contactGroupId String?
  contactGroup   ContactGroups? @relation(fields: [contactGroupId], references: [id], onDelete: SetNull)
  keepOld        Boolean        @default(true)
  contactsCount  Int            @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("import_contacts")
}

model ExportContact {
  id         String   @id @default(uuid())
  fieldNames String[] @default([])

  contactListId String?
  contactList   ContactList? @relation(fields: [contactListId], references: [id], onDelete: SetNull)

  contactGroupId String?
  contactGroup   ContactGroups? @relation(fields: [contactGroupId], references: [id], onDelete: SetNull)

  contactsCount Int        @default(0)
  exportType    ExportType // <- ye naya field, batayega LIST/GROUP/ALL_CONTACTS
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("export_contacts")
}
