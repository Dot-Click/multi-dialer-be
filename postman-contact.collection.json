{
  "info": {
    "_postman_id": "6c2c0a9f-0e83-4a3f-9a2e-1e9e6bb35b51",
    "name": "multi-dialer-be - Contact CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "PUT_YOUR_JWT_TOKEN_HERE" },
    { "key": "listId", "value": "PASTE_LIST_ID_HERE" },
    { "key": "contactId", "value": "PASTE_CONTACT_ID_HERE" }
  ],
  "item": [
    {
      "name": "Create Contact",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/contact/create",
          "host": ["{{baseUrl}}"],
          "path": ["api", "contact", "create"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"John Doe\",\n  \"address\": \"123 Main St\",\n  \"email\": \"john@example.com\",\n  \"city\": \"Dallas\",\n  \"state\": \"TX\",\n  \"zip\": \"75001\",\n  \"phoneNumber\": \"+15551234567\",\n  \"phoneType\": \"MOBILE\",\n  \"listId\": \"{{listId}}\"\n}\n"
        }
      },
      "response": [
        {
          "name": "201 - Success",
          "status": "Created",
          "code": 201,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Contact created\",\n  \"data\": {\n    \"id\": \"<contactId>\",\n    \"fullName\": \"John Doe\",\n    \"address\": \"123 Main St\",\n    \"email\": \"john@example.com\",\n    \"city\": \"Dallas\",\n    \"state\": \"TX\",\n    \"zip\": \"75001\",\n    \"phoneNumber\": \"+15551234567\",\n    \"phoneType\": \"MOBILE\",\n    \"listId\": \"<listId>\",\n    \"dataDialerId\": null,\n    \"list\": { \"id\": \"<listId>\", \"name\": \"January Calling List\", \"tag\": \"FOLLOW_UP\" }\n  }\n}\n"
        },
        {
          "name": "404 - List not found",
          "status": "Not Found",
          "code": 404,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"List not found\"\n}\n"
        }
      ]
    },
    {
      "name": "Get All Contacts",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/contact",
          "host": ["{{baseUrl}}"],
          "path": ["api", "contact"]
        }
      },
      "response": [
        {
          "name": "200 - Success",
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Contacts fetched\",\n  \"data\": [\n    {\n      \"id\": \"<contactId>\",\n      \"fullName\": \"John Doe\",\n      \"address\": \"123 Main St\",\n      \"email\": \"john@example.com\",\n      \"city\": \"Dallas\",\n      \"state\": \"TX\",\n      \"zip\": \"75001\",\n      \"phoneNumber\": \"+15551234567\",\n      \"phoneType\": \"MOBILE\",\n      \"listId\": \"<listId>\",\n      \"dataDialerId\": null,\n      \"list\": { \"id\": \"<listId>\", \"name\": \"January Calling List\", \"tag\": \"FOLLOW_UP\" }\n    }\n  ]\n}\n"
        }
      ]
    },
    {
      "name": "Get Contact By Id",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/contact/{{contactId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "contact", "{{contactId}}"]
        }
      },
      "response": [
        {
          "name": "200 - Success",
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Contact fetched\",\n  \"data\": {\n    \"id\": \"<contactId>\",\n    \"fullName\": \"John Doe\",\n    \"address\": \"123 Main St\",\n    \"email\": \"john@example.com\",\n    \"city\": \"Dallas\",\n    \"state\": \"TX\",\n    \"zip\": \"75001\",\n    \"phoneNumber\": \"+15551234567\",\n    \"phoneType\": \"MOBILE\",\n    \"listId\": \"<listId>\",\n    \"dataDialerId\": null,\n    \"list\": { \"id\": \"<listId>\", \"name\": \"January Calling List\", \"tag\": \"FOLLOW_UP\" }\n  }\n}\n"
        },
        {
          "name": "404 - Not found",
          "status": "Not Found",
          "code": 404,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Contact not found\"\n}\n"
        }
      ]
    },
    {
      "name": "Update Contact",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/contact/{{contactId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "contact", "{{contactId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"John Doe (Updated)\",\n  \"phoneType\": \"TELEPHONE\"\n}\n"
        }
      },
      "response": [
        {
          "name": "200 - Success",
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Contact updated\",\n  \"data\": {\n    \"id\": \"<contactId>\",\n    \"fullName\": \"John Doe (Updated)\",\n    \"phoneType\": \"TELEPHONE\"\n  }\n}\n"
        }
      ]
    },
    {
      "name": "Delete Contact",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/contact/{{contactId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "contact", "{{contactId}}"]
        }
      },
      "response": [
        {
          "name": "200 - Success",
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Contact deleted successfully\"\n}\n"
        }
      ]
    }
  ]
}


