  "ERROR_RESPONSES": {
    "missingFile": {
      "success": false,
      "message": "File is required"
    },
    "invalidMediaType": {
      "success": false,
      "message": "Validation error",
      "errors": [
        {
          "message": "Invalid enum value. Expected 'VOICE_MAIL' | 'ON_HOLD' | 'CALLBACK_MESSAGE' | 'EMAIL_VIDEO', received 'INVALID'",
          "path": ["mediaType"]
        }
      ]
    },
    "invalidFileType": {
      "success": false,
      "message": "Invalid file type for VOICE_MAIL. Allowed types: audio/mpeg, audio/mp3, audio/wav, audio/wave, audio/x-wav, audio/mp4, audio/m4a"
    },
    "fileSizeExceeded": {
      "success": false,
      "message": "File size exceeds maximum allowed size of 0.75MB for ON_HOLD"
    },
    "notFound": {
      "success": false,
      "message": "Media center item not found"
    },
    "unauthorized": {
      "success": false,
      "message": "you can only update your media center item not other media center item"
    }
  },
