{
  "apiBase": "http://localhost:3000/api",
  "module": "Lead Sheet (System Settings)",
  "notes": [
    "All routes are behind auth + ADMIN/OWNER role.",
    "If your auth uses cookies/sessions, the frontend request should include credentials (fetch: credentials:'include').",
    "Response shape uses successResponse/errorResponse from src/utils/handler.ts."
  ],
  "endpoints": [
    {
      "name": "Create Lead Sheet",
      "method": "POST",
      "path": "/system-settings/lead-sheet/create",
      "requestBody": {
        "title": "My Sales Script Lead Sheet",
        "questions": [
          { "text": "Full name", "type": "textfield" },
          { "text": "Best time to call", "type": "datetime" },
          {
            "text": "Lead type",
            "type": "dropdown",
            "options": ["Buyer", "Seller", "Investor"],
            "required": true
          },
          {
            "text": "Preferred contact method",
            "type": "radio",
            "options": ["Call", "Text", "Email"],
            "required": true
          },
          {
            "text": "Tags",
            "type": "checkbox",
            "options": ["Hot", "Warm", "Cold"],
            "required": true
          }
        ]
      },
      "successResponseExample": {
        "success": true,
        "message": "Lead Sheet created",
        "data": {
          "id": "cuid_xxx",
          "title": "My Sales Script Lead Sheet",
          "systemSettingId": "uuid_xxx",
          "createdAt": "2025-12-23T12:00:00.000Z",
          "updatedAt": "2025-12-23T12:00:00.000Z",
          "questions": [
            {
              "id": "cuid_q1",
              "text": "Full name",
              "type": "TEXTFIELD",
              "options": [],
              "required": null,
              "leadSheetId": "cuid_xxx",
              "createdAt": "2025-12-23T12:00:00.000Z",
              "updatedAt": "2025-12-23T12:00:00.000Z"
            }
          ],
          "systemSetting": {
            "user": { "id": "user_xxx", "fullName": "Example User", "email": "user@example.com" }
          }
        }
      },
      "errorResponseExamples": [
        {
          "when": "Duplicate title",
          "status": 400,
          "response": { "success": false, "message": "A Lead Sheet with this title already exists." }
        },
        {
          "when": "Invalid questions/options/required rules",
          "status": 400,
          "response": { "success": false, "message": "questions[2].options is required for DROPDOWN and must have at least 2 options." }
        }
      ]
    },
    {
      "name": "Get Lead Sheets (current user)",
      "method": "GET",
      "path": "/system-settings/lead-sheet",
      "successResponseExample": {
        "success": true,
        "message": "Lead Sheets fetched",
        "data": [
          {
            "id": "cuid_xxx",
            "title": "My Sales Script Lead Sheet",
            "systemSettingId": "uuid_xxx",
            "createdAt": "2025-12-23T12:00:00.000Z",
            "updatedAt": "2025-12-23T12:00:00.000Z",
            "questions": [
              {
                "id": "cuid_q1",
                "text": "Full name",
                "type": "TEXTFIELD",
                "options": [],
                "required": null,
                "leadSheetId": "cuid_xxx",
                "createdAt": "2025-12-23T12:00:00.000Z",
                "updatedAt": "2025-12-23T12:00:00.000Z"
              }
            ]
          }
        ]
      }
    },
    {
      "name": "Get Lead Sheet by ID (current user)",
      "method": "GET",
      "path": "/system-settings/lead-sheet/:id",
      "pathParamsExample": { "id": "cuid_xxx" },
      "successResponseExample": {
        "success": true,
        "message": "Lead Sheet fetched",
        "data": {
          "id": "cuid_xxx",
          "title": "My Sales Script Lead Sheet",
          "systemSettingId": "uuid_xxx",
          "createdAt": "2025-12-23T12:00:00.000Z",
          "updatedAt": "2025-12-23T12:00:00.000Z",
          "questions": []
        }
      },
      "errorResponseExamples": [
        {
          "when": "Not found / not owned by user",
          "status": 404,
          "response": { "success": false, "message": "Lead Sheet not found" }
        }
      ]
    },
    {
      "name": "Update Lead Sheet (replaces questions if provided)",
      "method": "PUT",
      "path": "/system-settings/lead-sheet/:id",
      "pathParamsExample": { "id": "cuid_xxx" },
      "requestBody": {
        "title": "Updated Lead Sheet Title",
        "questions": [
          { "text": "First name", "type": "textfield" },
          { "text": "Last name", "type": "textfield" },
          { "text": "Status", "type": "dropdown", "options": ["New", "Working", "Closed"], "required": true }
        ]
      },
      "successResponseExample": {
        "success": true,
        "message": "Lead Sheet updated",
        "data": {
          "id": "cuid_xxx",
          "title": "Updated Lead Sheet Title",
          "questions": [
            { "id": "cuid_q1_new", "text": "First name", "type": "TEXTFIELD", "options": [], "required": null }
          ]
        }
      }
    },
    {
      "name": "Delete Lead Sheet",
      "method": "DELETE",
      "path": "/system-settings/lead-sheet/:id",
      "pathParamsExample": { "id": "cuid_xxx" },
      "successResponseExample": {
        "success": true,
        "message": "Lead Sheet deleted successfully"
      }
    }
  ],
  "validationRules": {
    "questionTypesAllowedFromFrontend": ["textfield", "dropdown", "checkbox", "radio", "datetime"],
    "optionsRule": "options is required only for dropdown/checkbox/radio, and must have at least 2 non-empty strings.",
    "requiredRule": "required must be true only for dropdown/checkbox/radio. For other types, required must be omitted or false."
  }
}


